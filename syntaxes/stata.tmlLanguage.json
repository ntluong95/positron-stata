{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Stata",
  "scopeName": "source.stata",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#macros"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#control"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#commands"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#mata"
    },
    {
      "include": "#official-commands"
    },
    {
      "include": "#community-commands"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#subscripts"
    },
    {
      "include": "#macro-local"
    },
    {
      "include": "#macro-global"
    },
    {
      "include": "#string-compound"
    },
    {
      "include": "#string-regular"
    },
    {
      "include": "#macro-commands"
    },
    {
      "include": "#factorvariables"
    },
    {
      "include": "#control-flow"
    },
    {
      "include": "#prefixes"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.stata",
          "begin": "/\\*",
          "end": "\\*/"
        },
        {
          "name": "comment.line.double-slash.stata",
          "match": "//.*$"
        },
        {
          "name": "comment.line.triple-slash.stata",
          "match": "///.*$"
        },
        {
          "name": "comment.line.star.stata",
          "match": "^\\s*\\*.*$"
        },
        {
          "include": "#comments-block"
        },
        {
          "include": "#comments-double-slash"
        },
        {
          "include": "#comments-star"
        },
        {
          "include": "#comments-triple-slash"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.compound.stata",
          "begin": "`\"",
          "end": "\"'"
        },
        {
          "name": "string.quoted.double.stata",
          "begin": "\"",
          "end": "\""
        }
      ]
    },
    "macros": {
      "patterns": [
        {
          "name": "variable.other.local.stata",
          "match": "`[a-zA-Z_][a-zA-Z0-9_]*'"
        },
        {
          "name": "variable.other.local.stata",
          "match": "`[^']*'"
        },
        {
          "name": "variable.other.global.stata",
          "match": "\\$\\{?[a-zA-Z_][a-zA-Z0-9_]*\\}?"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.stata",
          "match": "\\b[0-9]+(\\.[0-9]+)?([eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.language.missing.stata",
          "match": "\\b\\.[a-z]?\\b"
        }
      ]
    },
    "control": {
      "patterns": [
        {
          "name": "keyword.control.stata",
          "match": "\\b(if|else|while|foreach|forvalues|in|of|local|global|program|end|define|exit|continue|break|return|mata|version|qui|quietly|cap|capture|noi|noisily|preserve|restore|tempvar|tempname|tempfile|args|syntax|confirm|gettoken|tokenize|timer|set)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.other.stata",
          "match": "\\b(using|replace|clear|all|varlist|newlist|string|numeric|integer|matrix|scalar|var|by|bysort|sort|xi|svy|mi|st|xt|me|sem|gsem|bayesmh)\\b"
        },
        {
          "name": "support.type.stata",
          "match": "\\b(byte|int|long|float|double|str[0-9]*|strL)\\b"
        }
      ]
    },
    "commands": {
      "patterns": [
        {
          "name": "support.function.data.stata",
          "match": "\\b(use|save|import|export|insheet|outsheet|infile|infix|merge|append|reshape|collapse|contract|fillin|cross|joinby|stack|xpose|compress|recast|destring|tostring|encode|decode)\\b"
        },
        {
          "name": "support.function.manipulation.stata",
          "match": "\\b(gen|generate|replace|drop|keep|rename|recode|label|order|sort|gsort|duplicates|isid|levelsof|egen|bysort|assert|count|distinct|fre)\\b"
        },
        {
          "name": "support.function.statistics.stata",
          "match": "\\b(regress|reg|logit|logistic|probit|ologit|oprobit|mlogit|poisson|nbreg|tobit|truncreg|heckman|ivregress|ivreg2|xtreg|xtivreg|xtlogit|xtpoisson|areg|reghdfe|didregress|diff_in_diff|rdrobust|synth|binscatter|lpoly|lowess|qreg|rreg|sureg|sem|gsem|mixed|melogit|bayesmh|bayes|bootstrap|jackknife|permute|simulate|power|sampsi)\\b"
        },
        {
          "name": "support.function.descriptive.stata",
          "match": "\\b(summarize|sum|tabulate|tab|table|describe|des|codebook|inspect|list|browse|br|edit|ed|display|di|correlate|cor|pwcorr|mean|proportion|ratio|total|ci|centile|pctile|xtile|histogram|kdensity|stem|symplot|qnorm|pnorm|gladder|ladder)\\b"
        },
        {
          "name": "support.function.testing.stata",
          "match": "\\b(test|testnl|lincom|nlcom|margins|marginsplot|contrast|pwcompare|predict|estat|fitstat|lrtest|hausman|overid|weakiv|ivendog|anova|oneway|ttest|ranksum|signrank|kwallis|ksmirnov|swilk|sktest|vif|hettest|bpagan|dwstat|durbina|actest|archlm|ovtest|linktest)\\b"
        },
        {
          "name": "support.function.graphics.stata",
          "match": "\\b(graph|twoway|scatter|line|connected|area|bar|dot|box|pie|histogram|kdensity|qnorm|pnorm|qqplot|spike|dropline|rarea|rbar|rcap|rline|rscatter|rcapsym|function|matrix|combine|hbar|scheme|grstyle|coefplot|plotmatrix|maptile|spmap|grmap)\\b"
        },
        {
          "name": "support.function.io.stata",
          "match": "\\b(sysuse|webuse|bcuse|freduse|wbopendata|cd|dir|ls|copy|erase|mkdir|rmdir|type|cat|file|filefilter|log|cmdlog|translate|set|query|adopath|ssc|net|ado|which|findfile|mata)\\b"
        },
        {
          "name": "support.function.estimation.stata",
          "match": "\\b(eststo|esttab|estout|estimates|ereturn|return|matrix|scalar|constraint|ml|gmm|nlsur|frontier|stcox|streg|stset|stdes|stsum|sts|stcurve|stpower|ltable|ctset|snapshot)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.stata",
          "match": "(==|!=|>=|<=|>|<)"
        },
        {
          "name": "keyword.operator.logical.stata",
          "match": "\\b(\\&|\\||!)\\b|&&|\\|\\|"
        },
        {
          "name": "keyword.operator.arithmetic.stata",
          "match": "(\\+|-|\\*|/|\\^)"
        },
        {
          "name": "keyword.operator.assignment.stata",
          "match": "="
        },
        {
          "comment": "Arithmetic operators - exclude /* and */ to avoid capturing block comment delimiters",
          "match": "\\+\\+|\\-\\-|\\+|\\-|(?<!/)\\*(?!/)|\\^",
          "name": "keyword.operator.arithmetic.stata"
        },
        {
          "comment": "Division operator - avoid matching // comments and /* block comment open",
          "match": "/(?![/*])",
          "name": "keyword.operator.arithmetic.stata"
        },
        {
          "match": "\\&|\\|",
          "name": "keyword.operator.logical.stata"
        },
        {
          "match": "(?:<=|>=|:=|==|!=|~=|<|>|=|!!|!)",
          "name": "keyword.operator.comparison.stata"
        },
        {
          "match": "\\(|\\)",
          "name": "keyword.operator.parentheses.stata"
        },
        {
          "match": "(##|#)",
          "name": "keyword.operator.factor-variables.stata"
        },
        {
          "match": "%",
          "name": "keyword.operator.format.stata"
        },
        {
          "match": ":",
          "name": "punctuation.separator.key-value"
        },
        {
          "match": "\\[",
          "name": "punctuation.definition.parameters.begin.stata"
        },
        {
          "match": "\\]",
          "name": "punctuation.definition.parameters.end.stata"
        },
        {
          "match": ",",
          "name": "punctuation.separator.stata"
        },
        {
          "match": ";",
          "name": "keyword.operator.delimiter.stata"
        }
      ]
    },
    "comments-block": {
      "begin": "/\\*",
      "end": "\\*/",
      "name": "comment.block.stata",
      "patterns": [
        {
          "include": "#comments-block"
        }
      ]
    },
    "comments-star": {
      "begin": "^\\s*(\\*)(?!/)",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.comment.stata"
        }
      },
      "end": "(?=\\n)",
      "name": "comment.line.star.stata",
      "patterns": [
        {
          "begin": "///",
          "end": "\\n",
          "name": "comment.line-continuation.stata"
        }
      ]
    },
    "comments-triple-slash": {
      "begin": "(^///|(?<=\\s)///)",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.comment.stata"
        }
      },
      "end": "(?=\\n)",
      "name": "comment.line.triple-slash.stata"
    },
    "comments-double-slash": {
      "begin": "(^//|(?<=\\s)//)(?!/)",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.comment.stata"
        }
      },
      "end": "(?=\\n)",
      "name": "comment.line.double-slash.stata"
    },
    "constants": {
      "patterns": [
        {
          "include": "#factorvariables"
        },
        {
          "match": "\\b(?i:(\\d+\\.\\d*(e[\\-\\+]?\\d+)?))(?=[^a-zA-Z_])",
          "name": "constant.numeric.float.stata"
        },
        {
          "match": "(?<=[^0-9a-zA-Z_])(?i:(\\.\\d+(e[\\-\\+]?\\d+)?))",
          "name": "constant.numeric.float.stata"
        },
        {
          "match": "\\b(?i:(\\d+e[\\-\\+]?\\d+))",
          "name": "constant.numeric.float.stata"
        },
        {
          "match": "\\b(\\d+)\\b",
          "name": "constant.numeric.integer.decimal.stata"
        },
        {
          "match": "\\.(a|b|c|d|e|f|g|h|i|j|k|l|m|n|o|p|q|r|s|t|u|v|w|x|y|z)?(?![\\w])",
          "name": "constant.language.missing.stata"
        },
        {
          "match": "\\b(_pi|_rc|_merge|_N|_n|_all|_col|_skip|_dta|_b|_coef|_cons|_se|_pred)\\b",
          "name": "constant.language.builtin.stata"
        }
      ]
    },
    "factorvariables": {
      "patterns": [
        {
          "comment": "Factor variable notation: i(level), c(var), o(var), ib2.var, ib(spec).var, i(range).var, etc.",
          "match": "\\b(?:i(?:\\((?:\\d+|\\d+/\\d+)\\))?|c|o|i?b(?:\\d+|n|\\((?:#?\\d+|first|last|freq)\\))?)\\.(?=[a-zA-Z_]|\\()",
          "name": "constant.language.factorvars.stata"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "begin": "\\b((abbrev|abs|acos|acosh|asin|asinh|atan|atan2|atanh|autocode|betaden|binomial|binomialp|binomialtail|byteorder|c|cauchy|cauchyden|cauchytail|ceil|char|chi2|chi2den|chi2tail|cholesky|chop|clip|clock|Clock|cloglog|coleqnumb|collatorlocale|collatorversion|colnfreeparms|colnumb|colsof|comb|cond|corr|cos|cosh|daily|date|day|det|dhms|diag|diag0cnt|digamma|dofb|dofc|dofh|dofm|dofq|dofw|dofy|dow|doy|dunnettprob|e|el|epsdouble|epsfloat|exp|exponential|exponentialden|exponentialtail|F|Fden|fileexists|fileread|filereaderror|filewrite|float|floor|fmtwidth|Ftail|gammaden|gammap|gammaptail|get|hadamard|halfyear|halfyearly|hh|hms|hofd|hours|hypergeometric|hypergeometricp|I|ibeta|ibetatail|igaussian|igaussianden|igaussiantail|indexnot|inlist|inrange|int|inv|invbinomial|invbinomialtail|invcauchy|invcauchytail|invchi2|invchi2tail|invcloglog|invdunnettprob|invexponential|invexponentialtail|invF|invFtail|invgammap|invgammaptail|invibeta|invibetatail|invigaussian|invigaussiantail|invlaplace|invlaplacetail|invlogistic|invlogistictail|invlogit|invnbinomial|invnbinomialtail|invnchi2|invnchi2tail|invnF|invnFtail|invnibeta|invnormal|invnt|invnttail|invpoisson|invpoissontail|invsym|invt|invttail|invtukeyprob|invweibull|invweibullph|invweibullphtail|invweibulltail|irecode|issymmetric|itrim|J|laplace|laplaceden|laplacetail|length|ln|lncauchyden|lnfactorial|lngamma|lnigammaden|lnigaussianden|lniwishartden|lnlaplaceden|lnmvnormalden|lnnormal|lnnormalden|lnwishartden|log|log10|logistic|logisticden|logistictail|logit|lower|ltrim|matmissing|matrix|matuniform|max|maxbyte|maxdouble|maxfloat|maxint|maxlong|mdy|mdyhms|mi|min|minbyte|mindouble|minfloat|minint|minlong|minutes|missing|mm|mod|mofd|month|monthly|mreldif|msofhours|msofminutes|msofseconds|nbetaden|nbinomial|nbinomialp|nbinomialtail|nchi2|nchi2den|nchi2tail|nF|nFden|nFtail|nibeta|normal|normalden|npnchi2|npnF|npnt|nt|ntden|nttail|nullmat|plural|poisson|poissonp|poissontail|proper|qofd|quarter|quarterly|r|rbeta|rbinomial|rcauchy|rchi2|real|recode|regexm|regexr|regexs|reldif|replay|return|reverse|rexponential|rgamma|rhypergeometric|rigaussian|rlaplace|rlogistic|rnbinomial|rnormal|round|roweqnumb|rownfreeparms|rownumb|rowsof|rpoisson|rt|rtrim|runiform|runiformint|rweibull|rweibullph|s|scalar|seconds|sign|sin|sinh|smallestdouble|soundex|sqrt|ss|string|stritrim|strlen|strlower|strltrim|strmatch|strofreal|strpos|strproper|strreverse|strrpos|strrtrim|strtoname|strtrim|strupper|subinstr|subinword|substr|sum|sweep|t|tan|tanh|tc|tC|td|tden|th|tin|tm|tobytes|tq|trace|trigamma|trim|trunc|ttail|tukeyprob|tw|twithin|uchar|udstrlen|udsubstr|uisdigit|uisletter|upper|ustrcompare|ustrcompareex|ustrfix|ustrfrom|ustrinvalidcnt|ustrleft|ustrlen|ustrlower|ustrltrim|ustrnormalize|ustrpos|ustrregexm|ustrregexra|ustrregexrf|ustrregexs|ustrreverse|ustrright|ustrrpos|ustrrtrim|ustrsortkey|ustrsortkeyex|ustrtitle|ustrto|ustrtohex|ustrtoname|ustrtrim|ustrunescape|ustrupper|ustrword|ustrwordcount|usubinstr|usubstr|vec|vecdiag|week|weekly|weibull|weibullden|weibullph|weibullphden|weibullphtail|weibulltail|wofd|word|wordbreaklocale|wordcount|year|yearly|yh|ym|yofd|yq|yw))(\\()",
          "beginCaptures": {
            "2": {
              "name": "support.function.builtin.stata"
            },
            "3": {
              "name": "punctuation.definition.parameters.begin.stata"
            }
          },
          "end": "(\\))",
          "endCaptures": {
            "1": {
              "name": "punctuation.definition.parameters.end.stata"
            }
          },
          "patterns": [
            {
              "include": "#functions"
            },
            {
              "include": "#constants"
            },
            {
              "include": "#operators"
            },
            {
              "include": "#macro-local"
            },
            {
              "include": "#macro-global"
            },
            {
              "include": "#string-compound"
            },
            {
              "include": "#string-regular"
            }
          ]
        }
      ]
    },
    "macro-commands": {
      "patterns": [
        {
          "begin": "\\b(loc(al|a)?)\\s+",
          "beginCaptures": {
            "1": {
              "name": "keyword.macro.stata"
            }
          },
          "end": "(?=\\n|//|/\\*)",
          "patterns": [
            {
              "include": "#extended-macro-functions"
            },
            {
              "include": "#macro-local"
            },
            {
              "include": "#macro-global"
            },
            {
              "include": "#operators"
            },
            {
              "include": "#string-compound"
            },
            {
              "include": "#string-regular"
            },
            {
              "include": "#constants"
            }
          ]
        },
        {
          "begin": "\\b(gl(obal|oba|ob|o)?)\\s+",
          "beginCaptures": {
            "1": {
              "name": "keyword.macro.stata"
            }
          },
          "end": "(?=\\n|//|/\\*)",
          "patterns": [
            {
              "include": "#macro-local"
            },
            {
              "include": "#macro-global"
            },
            {
              "include": "#operators"
            },
            {
              "include": "#string-compound"
            },
            {
              "include": "#string-regular"
            },
            {
              "include": "#constants"
            }
          ]
        },
        {
          "begin": "\\b(tempvar|tempname|tempfile)\\s+",
          "beginCaptures": {
            "1": {
              "name": "keyword.macro.stata"
            }
          },
          "end": "(?=$|//|/\\*)",
          "patterns": [
            {
              "match": "\\w{1,31}",
              "name": "entity.name.type.class.stata"
            }
          ]
        }
      ]
    },
    "macro-local": {
      "patterns": [
        {
          "begin": "`(?!\")",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.variable.begin.stata"
            }
          },
          "end": "'",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.variable.end.stata"
            }
          },
          "name": "variable.other.macro.local.stata",
          "patterns": [
            {
              "match": "\\+\\+|\\-\\-",
              "name": "keyword.operator.arithmetic.stata"
            },
            {
              "include": "#macro-local"
            },
            {
              "include": "#macro-global"
            },
            {
              "match": "\\w{1,31}",
              "name": "entity.name.variable.local.stata"
            }
          ]
        }
      ]
    },
    "macro-global": {
      "patterns": [
        {
          "begin": "\\$\\{",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.variable.begin.stata"
            }
          },
          "end": "\\}",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.variable.end.stata"
            }
          },
          "name": "variable.other.macro.global.stata",
          "patterns": [
            {
              "include": "#macro-local"
            },
            {
              "include": "#macro-global"
            },
            {
              "match": "\\w{1,32}",
              "name": "entity.name.variable.global.stata"
            }
          ]
        },
        {
          "begin": "\\$(?=[a-zA-Z_])",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.variable.begin.stata"
            }
          },
          "end": "(?![\\w])",
          "name": "variable.other.macro.global.stata",
          "patterns": [
            {
              "include": "#macro-local"
            },
            {
              "include": "#macro-global"
            },
            {
              "match": "[a-zA-Z_]\\w{0,31}",
              "name": "entity.name.variable.global.stata"
            }
          ]
        }
      ]
    },
    "extended-macro-functions": {
      "patterns": [
        {
          "comment": "Extended macro functions with colon operator: :word count, :list sort, :type, etc.",
          "match": "(`)(:)\\s+(word|list|type|format|variable|label|value|sort|uniq|length|strlen|copy|all|scalar|matrix|local|global|permname|substr|subinstr)\\b",
          "captures": {
            "1": {
              "name": "punctuation.definition.variable.begin.stata"
            },
            "2": {
              "name": "keyword.operator.macro.stata"
            },
            "3": {
              "name": "keyword.other.extended-macro.stata"
            }
          }
        }
      ]
    },
    "string-compound": {
      "patterns": [
        {
          "begin": "`\"",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.stata"
            }
          },
          "end": "\"'|(?=\\n)",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.stata"
            }
          },
          "name": "string.quoted.double.compound.stata",
          "patterns": [
            {
              "include": "#string-compound"
            },
            {
              "include": "#macro-local"
            },
            {
              "include": "#macro-global"
            }
          ]
        }
      ]
    },
    "string-regular": {
      "patterns": [
        {
          "begin": "(?<!`|`)\"",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.stata"
            }
          },
          "end": "\"|(?=\\n)",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.stata"
            }
          },
          "name": "string.quoted.double.stata",
          "patterns": [
            {
              "include": "#macro-local"
            },
            {
              "include": "#macro-global"
            }
          ]
        }
      ]
    },
    "subscripts": {
      "patterns": [
        {
          "begin": "(?<=[\\w'])(\\[)",
          "beginCaptures": {
            "1": {
              "name": "punctuation.definition.parameters.begin.stata"
            }
          },
          "end": "(\\])",
          "endCaptures": {
            "1": {
              "name": "punctuation.definition.parameters.end.stata"
            }
          },
          "name": "meta.subscripts.stata",
          "patterns": [
            {
              "match": "\\b(\\d*)(\\.\\.\\.|\\.\\.)\\b",
              "name": "constant.language.matrix_row.stata"
            },
            {
              "include": "#macro-local"
            },
            {
              "include": "#macro-global"
            },
            {
              "include": "#operators"
            },
            {
              "include": "#constants"
            },
            {
              "include": "#functions"
            },
            {
              "match": "_n|_N",
              "name": "variable.language.stata"
            }
          ]
        }
      ]
    },
    "control-flow": {
      "patterns": [
        {
          "match": "\\b(if|else if|else)\\b",
          "name": "keyword.control.conditional.stata"
        },
        {
